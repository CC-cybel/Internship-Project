NO_PROXY=127.0.0.1,localhost,0.0.0.0,::1

CANDIDATE_MODEL_NAME=qwen3_8b_rubric_rl_step540
CANDIDATE_API_BASE=http://127.0.0.1:8002/v1
CANDIDATE_API_KEY=

JUDGE_MODEL_NAME=deepseek-v4-flash
JUDGE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
