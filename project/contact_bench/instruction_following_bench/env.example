NO_PROXY=127.0.0.1,localhost,0.0.0.0,::1

CANDIDATE_MODEL_NAME=qwen3_8b_rubric_rl_step540
CANDIDATE_API_BASE=http://127.0.0.1:8002/v1
CANDIDATE_API_KEY=
CANDIDATE_MAX_OUTPUT_TOKENS=768
CANDIDATE_TEMPERATURE=0.6
CANDIDATE_TOP_P=0.95
CANDIDATE_TIMEOUT_S=180
PREFLIGHT_CANDIDATE=1

JUDGE_MODEL_NAME=deepseek-v4-flash
JUDGE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_API_KEY=

INPUT_FILE=./data/dataset/instruction_following_bench_final300.jsonl
OUTPUT=./output

# Default mode is online candidate generation followed by judge scoring.
# Set USE_REFERENCE=1 only for judge-only sanity checks against target.original_value.
# Set RESPONSE_FIELD only for offline evaluation of an existing model-output JSONL.
USE_REFERENCE=0
RESPONSE_FIELD=
RUN_NAME=

EVALUATION_LIMIT=0
OFFSET=0
CONCURRENCY=4
EVAL_RETRIES=4

JUDGE_MAX_TOKENS=1800
JUDGE_TIMEOUT_S=120
JUDGE_TEMPERATURE=0.0
